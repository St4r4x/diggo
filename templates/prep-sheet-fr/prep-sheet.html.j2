<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="prep-sheet.css">
</head>
<body>

<div class="header">
  <div class="header-company">{{ company }}</div>
  <div class="header-meta">{{ role }} &nbsp;·&nbsp; {{ date_str }}</div>
</div>

<div class="section-title">Entreprise</div>

<div class="company-summary">{{ company_summary }}</div>

{% if tech_stack %}
<div class="tech-badges">
  {% for tech in tech_stack %}
  <span class="badge">{{ tech }}</span>
  {% endfor %}
</div>
{% endif %}

<div class="section-title">Questions d'entretien</div>

{% for q in questions %}
<div class="question-block">
  <div class="question-theme">{{ q.theme }}</div>
  <div class="question-text">{{ q.question }}</div>
</div>
{% endfor %}

</body>
</html>
